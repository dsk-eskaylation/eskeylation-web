# Sao chép thành .env và điền giá trị thật (KHÔNG commit .env)

# Supabase PostgreSQL — dùng connection pooler (PgBouncer), driver asyncpg
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres

# Redis cho Celery
REDIS_URL=redis://localhost:6379/0

# Storage: local (dev) | supabase (prod)
STORAGE_BACKEND=local
# Thư mục media cục bộ (khi local)
MEDIA_ROOT=media

# Supabase Storage (khi STORAGE_BACKEND=supabase)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_key>
STORAGE_BUCKET=media

# JWT — đặt chuỗi bí mật ngẫu nhiên đủ dài cho production
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Môi trường: dev | prod
ENVIRONMENT=dev

# CORS — origin frontend, khai báo dạng JSON list
CORS_ORIGINS=["http://localhost:5173"]
